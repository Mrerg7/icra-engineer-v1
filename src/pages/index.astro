---
import MainLayout from '../layouts/MainLayout.astro';

const contactEmail = "sales@desertrich.com";
const subjectLine = "Acquisition Inquiry — icra.engineer";
const mailtoLink = `mailto:${contactEmail}?subject=${encodeURIComponent(subjectLine)}`;

const marketStats = [
  { value: "$30B+", label: "Annual U.S. hospital & clinic construction spend", detail: "Ongoing investment in new facilities and renovations drives demand for specialized engineering solutions that integrate infection control requirements.", icon: "hospital" },
  { value: "Technical Gap", label: "Most engineers lack deep ICRA expertise", detail: "General mechanical, electrical, and plumbing engineers often lack specialized knowledge in ICRA classifications, containment strategies, and healthcare-specific airflow requirements.", icon: "warning" },
  { value: "High-Value Niche", label: "Specialized ICRA engineering commands premium fees", detail: "Projects involving complex isolation rooms, OR renovations, and containment during construction require specialized expertise that can command premium engineering fees.", icon: "trophy" },
];

const brandPillars = [
  { title: "Airflow & Pressure Engineering", desc: "Design and verification of negative pressure systems, isolation room airflow, HEPA filtration strategies, and pressure cascade requirements for healthcare facilities.", icon: "wind" },
  { title: "Containment & Barrier Design", desc: "Engineering of temporary and permanent containment systems, barrier specifications, and dust/infection control measures for construction in occupied healthcare environments.", icon: "compass" },
  { title: "ICRA Technical Consulting", desc: "Technical review of ICRA plans, engineering support for Class I–IV protocols, and specialized input during pre-construction planning and construction phases.", icon: "clipboard" },
  { title: "Healthcare MEP Specialization", desc: "Mechanical, electrical, and plumbing engineering expertise tailored to healthcare facilities with integrated infection control requirements.", icon: "cogs" },
];

const domainValues = [
  { title: ".engineer TLD Advantage", desc: "The .engineer extension is modern, professional, and instantly signals technical expertise. It differentiates you from general consultants and positions you as a specialized engineering professional.", icon: "globe" },
  { title: "Professional Email & Presence", desc: "@icra.engineer addresses project technical credibility and expertise. Ideal for proposals, engineering reports, client communications, and professional networking.", icon: "mail" },
  { title: "Clean & Brandable", desc: "Short, professional, and easy to communicate. Works exceptionally well for a technical consulting website, engineering proposals, and professional branding.", icon: "link" },
  { title: "Strong Technical Search Alignment", desc: "Excellent match for searches such as \"ICRA engineer\", \"healthcare construction engineer\", \"infection control engineer\", \"negative pressure design\", and related technical B2B terms.", icon: "search" },
  { title: "Scalable & Future-Proof", desc: "The brand supports growth from solo engineering practitioner to a specialized engineering firm, and can expand into training, software tools, or standards development.", icon: "refresh" },
  { title: "Multiple High-Value Revenue Streams", desc: "Project-based engineering consulting • Retainer technical advisory • Containment system design • Airflow modeling and verification • Training for engineers and contractors.", icon: "rocket" },
];

const businessModels = [
  { title: "Specialized ICRA Engineering Firm", desc: "Build a premier engineering practice focused on containment design, negative pressure systems, and infection control engineering for healthcare construction.", icon: "wind" },
  { title: "Technical Consulting & Design Services", desc: "Offer specialized engineering consulting for ICRA plans, containment systems, and healthcare facility modifications during construction and renovation.", icon: "compass" },
  { title: "Modeling & Verification Tools", desc: "Develop or offer airflow modeling, pressure verification, and technical documentation tools under a highly credible technical brand.", icon: "laptop" },
  { title: "Training for Engineers & Contractors", desc: "Develop and deliver specialized training programs on ICRA engineering principles for mechanical engineers, contractors, and facility teams.", icon: "teacher" },
];

const buyerProfiles = [
  { title: "Mechanical & HVAC Engineers", desc: "Establish the leading brand for specialized infection control and negative pressure engineering in healthcare facilities.", icon: "cogs" },
  { title: "Containment & Construction Engineers", desc: "Position your practice as the go-to expert for technical containment design during healthcare construction and renovation.", icon: "compass" },
  { title: "Healthcare Facility Engineers", desc: "Build a specialized practice focused on ICRA-compliant engineering for hospitals, clinics, and medical facilities.", icon: "medical" },
  { title: "Technical Consulting Practices", desc: "Rebrand or launch a specialized ICRA engineering advisory service under a clear, credible, and ownable technical brand.", icon: "tie" },
  { title: "Training & Education Providers", desc: "Develop specialized training programs for engineers and contractors on ICRA engineering principles.", icon: "grad" },
  { title: "Strategic Investors & Acquirers", desc: "Acquire a clean, professional .engineer domain with clear commercial application in a growing, high-value technical niche.", icon: "globe" },
];
---

<MainLayout>
  <!-- ============================================ -->
  <!-- NAVBAR                                       -->
  <!-- ============================================ -->
  <nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
    <div class="max-w-screen-2xl mx-auto">
      <div class="px-8 py-5 flex items-center justify-between">
        <div class="flex items-center gap-x-3">
          <!-- Logo -->
          <div class="flex items-center gap-x-2.5">
            <div class="w-9 h-9 bg-icra-teal rounded-2xl flex items-center justify-center shadow-inner">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
            </div>
            <div>
              <span class="font-semibold tracking-tighter text-3xl">icra</span>
              <span class="text-icra-teal font-semibold text-3xl">.engineer</span>
            </div>
          </div>
          <div class="premium-badge flex items-center gap-x-1.5 ml-1">
            <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <span class="font-semibold tracking-[0.5px] text-[10px]">PREMIUM</span>
          </div>
        </div>

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
          <a href="#opportunity" class="text-slate-600 hover:text-slate-900 transition-colors">Opportunity</a>
          <a href="#brand" class="text-slate-600 hover:text-slate-900 transition-colors">The Brand</a>
          <a href="#why-domain" class="text-slate-600 hover:text-slate-900 transition-colors">Why This Domain</a>
          <a href="#acquire" class="text-slate-600 hover:text-slate-900 transition-colors">Acquire</a>
        </div>

        <div class="flex items-center gap-x-3">
          <a href={mailtoLink}
             class="hidden md:block px-5 py-2.5 text-sm font-semibold bg-white border border-slate-300 hover:border-slate-400 text-slate-700 rounded-3xl transition-all active:scale-[0.985]">
            Make an Offer
          </a>
          <a href={mailtoLink}
             class="px-6 py-2.5 text-sm font-semibold bg-icra-teal hover:bg-icra-deep text-white rounded-3xl transition-all active:scale-[0.985] shadow-sm flex items-center gap-x-2">
            <span>Inquire Now</span>
          </a>

          <!-- Mobile menu toggle -->
          <button class="md:hidden w-10 h-10 flex items-center justify-center text-slate-600" id="mobile-menu-btn">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-b border-slate-200 px-6 py-4">
      <div class="flex flex-col gap-y-3 text-sm font-medium">
        <a href="#opportunity" class="py-1.5 text-slate-700">Opportunity</a>
        <a href="#brand" class="py-1.5 text-slate-700">The Brand</a>
        <a href="#why-domain" class="py-1.5 text-slate-700">Why This Domain</a>
        <a href="#acquire" class="py-1.5 text-slate-700">Acquire</a>
        <div class="pt-3 border-t">
          <a href={mailtoLink}
             class="block w-full py-3 text-center text-sm font-semibold bg-icra-teal text-white rounded-3xl">Inquire Now</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- ============================================ -->
  <!-- HERO                                         -->
  <!-- ============================================ -->
  <header class="healthcare-gradient text-white">
    <div class="max-w-screen-2xl mx-auto px-8 pt-16 pb-20 md:pt-20 md:pb-24">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-x-2 bg-white/10 backdrop-blur-md px-4 py-1.5 rounded-3xl mb-6 border border-white/20">
          <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse-slow"></div>
          <span class="text-sm font-medium tracking-wide">EXCLUSIVELY AVAILABLE</span>
        </div>

        <h1 class="text-6xl md:text-7xl leading-[1.05] tracking-tighter font-semibold mb-4">
          icra.engineer
        </h1>

        <p class="max-w-3xl text-2xl md:text-3xl text-teal-100 tracking-tight mb-3">
          The professional brand for ICRA Engineering.
        </p>

        <p class="max-w-2xl text-lg text-teal-200/90 mb-9">
          Own the .engineer domain that positions you as the technical expert in Infection Control Risk Assessment —
          containment design, airflow engineering, negative pressure systems, and specialized healthcare facility engineering.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href={mailtoLink}
             class="group inline-flex items-center justify-center gap-x-3 px-8 py-4 bg-white text-teal-700 font-semibold text-lg rounded-3xl hover:bg-teal-50 active:bg-white transition-all shadow-xl shadow-black/10">
            <span>Secure This Domain</span>
            <svg class="w-5 h-5 group-active:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>

          <a href="#opportunity"
             class="inline-flex items-center justify-center gap-x-2 px-7 py-4 border border-white/30 hover:bg-white/10 text-white font-medium rounded-3xl transition-all text-lg">
            <span>Explore the Opportunity</span>
          </a>
        </div>

        <div class="mt-8 flex items-center gap-x-6 text-sm">
          <div class="flex items-center -space-x-1">
            <div class="w-6 h-6 bg-white/20 rounded-full border border-white/40"></div>
            <div class="w-6 h-6 bg-white/20 rounded-full border border-white/40"></div>
            <div class="w-6 h-6 bg-white/20 rounded-full border border-white/40"></div>
          </div>
          <span class="text-teal-200 text-sm">The technical authority in infection control engineering for healthcare construction</span>
        </div>
      </div>
    </div>
  </header>

  <!-- ============================================ -->
  <!-- TRUST / STATS BAR                            -->
  <!-- ============================================ -->
  <div class="border-b border-slate-200 bg-white">
    <div class="max-w-screen-2xl mx-auto px-8 py-5">
      <div class="flex flex-wrap justify-center md:justify-between items-center gap-x-8 gap-y-4 text-center md:text-left">
        <div class="flex items-center gap-x-3">
          <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="font-medium text-sm text-slate-600">.engineer TLD — signals technical expertise & professionalism</span>
        </div>
        <div class="flex items-center gap-x-3">
          <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="font-medium text-sm text-slate-600">Healthcare facilities require specialized engineering for infection control</span>
        </div>
        <div class="flex items-center gap-x-3">
          <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <span class="font-medium text-sm text-slate-600">Technical ICRA expertise is in high demand for complex projects</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- THE OPPORTUNITY                              -->
  <!-- ============================================ -->
  <section id="opportunity" class="max-w-screen-2xl mx-auto px-8 pt-16 pb-12">
    <div class="max-w-3xl mb-10">
      <div class="uppercase tracking-[2px] text-icra-teal text-xs font-semibold mb-2">THE MARKET</div>
      <h2 class="text-4xl font-bold tracking-tighter leading-tight">Healthcare construction increasingly requires specialized technical engineering expertise for infection control.</h2>
      <p class="mt-4 text-lg text-slate-600">Modern healthcare facilities demand sophisticated engineering solutions for infection control — from negative pressure isolation rooms and operating room air handling systems to containment design during construction and renovation. General engineering firms often lack deep ICRA-specific knowledge. This creates strong demand for specialized ICRA engineering services that combine technical expertise with practical understanding of construction in occupied healthcare environments.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      {marketStats.map((stat) => (
        <div class="bg-white border border-slate-200 rounded-3xl p-7 modern-card">
          <div class="flex justify-between items-start">
            <div>
              <div class="text-5xl font-semibold tracking-tighter text-slate-900">{stat.value}</div>
              <div class="text-icra-teal font-medium mt-1">{stat.label}</div>
            </div>
            <div class="text-icra-teal-pale">
              {stat.icon === 'hospital' && <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>}
              {stat.icon === 'warning' && <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>}
              {stat.icon === 'trophy' && <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>}
            </div>
          </div>
          <p class="text-sm text-slate-500 mt-5 leading-snug">{stat.detail}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ============================================ -->
  <!-- THE BRAND                                    -->
  <!-- ============================================ -->
  <section id="brand" class="bg-white border-y border-slate-200 py-16">
    <div class="max-w-screen-2xl mx-auto px-8">
      <div class="max-w-3xl mb-10">
        <div class="uppercase tracking-[2px] text-icra-teal text-xs font-semibold mb-2">THE ICRA ENGINEER BRAND</div>
        <h2 class="text-4xl font-bold tracking-tighter leading-tight">What icra.engineer represents.</h2>
        <p class="mt-4 text-lg text-slate-600">This is the brand for the engineering professional or firm that brings specialized technical expertise to Infection Control Risk Assessment — combining engineering rigor with deep knowledge of healthcare construction and infection prevention requirements.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        {brandPillars.map((pillar) => (
          <div class="bg-slate-50 border border-slate-100 rounded-3xl p-6 modern-card">
            <div class="w-11 h-11 flex items-center justify-center bg-icra-teal-pale text-icra-teal rounded-2xl mb-5">
              {pillar.icon === 'wind' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.59 4.59A2 2 0 1111 8H2m10.59 11.41A2 2 0 1014 16H2m15.73-8.27A2.5 2.5 0 1119.5 12H2"/></svg>}
              {pillar.icon === 'compass' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>}
              {pillar.icon === 'clipboard' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>}
              {pillar.icon === 'cogs' && <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>}
            </div>
            <h4 class="font-semibold text-lg tracking-tight mb-2">{pillar.title}</h4>
            <p class="text-sm text-slate-600 leading-relaxed">{pillar.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- WHY THIS DOMAIN                              -->
  <!-- ============================================ -->
  <section id="why-domain" class="max-w-screen-2xl mx-auto px-8 py-16">
    <div class="max-w-3xl mb-9">
      <div class="uppercase tracking-[2px] text-icra-teal text-xs font-semibold mb-2">THE STRATEGIC ASSET</div>
      <h2 class="text-4xl font-bold tracking-tighter leading-tight">Why icra.engineer is a powerful professional brand.</h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {domainValues.map((item) => (
        <div class="value-prop bg-white border border-slate-200 p-7 rounded-3xl modern-card">
          <div class="flex items-center gap-x-3 mb-4">
            <div class="text-icra-teal">
              {item.icon === 'globe' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>}
              {item.icon === 'mail' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>}
              {item.icon === 'link' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>}
              {item.icon === 'search' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>}
              {item.icon === 'refresh' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>}
              {item.icon === 'rocket' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>}
            </div>
            <h4 class="font-semibold text-xl tracking-tight">{item.title}</h4>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ============================================ -->
  <!-- BUSINESS MODELS (dark)                       -->
  <!-- ============================================ -->
  <section class="bg-slate-900 text-white py-16">
    <div class="max-w-screen-2xl mx-auto px-8">
      <div class="max-w-2xl mb-9">
        <div class="text-teal-400 text-xs tracking-[2px] font-semibold mb-2">BUILD THE TECHNICAL PRACTICE</div>
        <h2 class="text-4xl tracking-tighter font-semibold">High-potential ways to activate icra.engineer.</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        {businessModels.map((model) => (
          <div class="bg-white/5 hover:bg-white/10 border border-white/10 p-6 rounded-3xl transition-colors">
            <div class="text-teal-400 mb-4">
              {model.icon === 'wind' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.59 4.59A2 2 0 1111 8H2m10.59 11.41A2 2 0 1014 16H2m15.73-8.27A2.5 2.5 0 1119.5 12H2"/></svg>}
              {model.icon === 'compass' && <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>}
